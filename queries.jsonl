{"id": "Q16", "description": "Find posts with titles containing 'algorithm' or 'data structure' and bodies discussing 'complexity' or 'optimization', excluding posts with 'dynamic programming' in the title.", "collection": "posts", "filter": {"$and": [{"$or": [{"title": {"$regex": "algorithm", "$options": "i"}}, {"title": {"$regex": "data structure", "$options": "i"}}]}, {"body": {"$regex": "complexity|optimization", "$options": "i"}}, {"title": {"$not": {"$regex": "dynamic programming", "$options": "i"}}}]}, "projection": {"title": 1, "body": 1, "tags": 1}}
