{"id": "Q14", "description": "Analyze user badge issuance trends, linking users to their top-scored posts and enriching with post history insights, focusing on obscure badge types and potential spam activity.", "collection": "users", "pipeline": [{"$match": {"badges": {"$exists": true, "$ne": [], "$type": "array"}, "userId": {"$gt": 1000}}}, {"$unwind": "$badges"}, {"$addFields": {"badgeClassNumeric": {"$toInt": "$badges.class"}, "badgeNameUpper": {"$toUpper": {"$ifNull": ["$badges.name", "UNKNOWN_BADGE"]}}}}, {"$lookup": {"from": "posts", "localField": "userId", "foreignField": "ownerUserId", "as": "userPosts"}}, {"$unwind": {"path": "$userPosts", "preserveNullAndEmptyArrays": true}}, {"$addFields": {"userPosts.scoreNumeric": {"$ifNull": ["$userPosts.score", 0]}, "userPosts.titleLength": {"$strLenCP": {"$ifNull": ["$userPosts.title", ""]}}}}, {"$group": {"_id": {"userId": "$userId", "displayName": "$displayName", "badgeId": "$badges.badgeId", "badgeName": "$badgeNameUpper", "badgeClass": "$badgeClassNumeric"}, "totalUserPosts": {"$sum": 1}, "highestScoringPostScore": {"$max": "$userPosts.scoreNumeric"}, "postsWithTags": {"$sum": {"$cond": [{"$and": [{"$isArray": "$userPosts.tags"}, {"$gt": [{"$size": "$userPosts.tags"}, 0]}]}, 1, 0]}}, "postsWithTitles": {"$sum": {"$cond": [{"$eq": ["$userPosts.titleLength", 0]}, 0, 1]}}, "postsWithBodyWords": {"$sum": {"$let": {"vars": {"bodyWords": {"$split": [{"$ifNull": ["$userPosts.body", ""]}, " "]}}, "in": {"$size": "$$bodyWords"}}}}, "recentBadgeDate": {"$max": "$badges.date"}}}, {"$group": {"_id": {"badgeId": "$_id.badgeId", "badgeName": "$_id.badgeName", "badgeClass": "$_id.badgeClass"}, "usersReceivingBadge": {"$push": {"userId": "$_id.userId", "displayName": "$_id.displayName", "totalUserPosts": "$totalUserPosts", "highestScoringPostScore": "$highestScoringPostScore", "postsWithTags": "$postsWithTags", "postsWithTitles": "$postsWithTitles", "postsWithBodyWords": "$postsWithBodyWords", "recentBadgeDate": "$recentBadgeDat